# ── Claude AI (content generation, SEO suggestions) ──────────────────────
# Bring your own key: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Image connectors (all optional — enable what you need) ───────────────
# Unsplash: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Pexels: https://www.pexels.com/api/
PEXELS_API_KEY=

# Getty Images: https://developers.gettyimages.com/
GETTY_API_KEY=
GETTY_API_SECRET=

# Cloudinary: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Supabase (optional backend: forms, auth, light DB, ecommerce) ────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Deploy targets (optional) ─────────────────────────────────────────────
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ── Site config ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_SITE_NAME=My Brand
